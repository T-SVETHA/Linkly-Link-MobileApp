{
  "name": "linkly-link-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix web_parent_dashboard",
    "build": "npm run build --prefix web_parent_dashboard",
    "preview": "npm run preview --prefix web_parent_dashboard",
    "test:e2e": "mocha mobile-tests/tests/*.test.js --reporter mobile-tests/tests/excel-reporter.cjs",
    "test:mobile": "mocha mobile-tests/tests/*.test.js --reporter mobile-tests/tests/excel-reporter.cjs",
    "test:security": "mocha mobile-tests/tests/*.test.js --reporter mobile-tests/tests/excel-reporter.cjs --grep \"\\[Security\\]\"",
    "test:load": "mocha mobile-tests/tests/*.test.js --reporter mobile-tests/tests/excel-reporter.cjs --grep \"\\[Performance\\]\""
  },
  "devDependencies": {
    "exceljs": "^4.4.0",
    "mocha": "^10.4.0"
  }
}

